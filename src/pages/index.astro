---
import BaseLayout from '../layouts/BaseLayout.astro';
import SlideNav from '../components/SlideNav.astro';
import Hero from '../components/Hero.astro';
import Projects from '../components/Projects.astro';
import Skills from '../components/Skills.astro';
import Contact from '../components/Contact.astro';
---

<BaseLayout
  title="Abubakar Mahmood - Junior Software Engineer"
  description="Junior Software Engineer in Lahore focused on Flutter, backend APIs, offline-first systems, and practical production-minded software."
>
  <SlideNav>
    <main id="slide-scroll" class="snap-y snap-mandatory h-screen w-full overflow-y-auto overflow-x-hidden">
      <div class="snap-start snap-always">
        <Hero />
      </div>
      <div class="snap-start snap-always">
        <Projects />
      </div>
      <div class="snap-start snap-always">
        <Skills />
      </div>
      <div class="snap-start snap-always">
        <Contact />
      </div>
    </main>
  </SlideNav>
</BaseLayout>
