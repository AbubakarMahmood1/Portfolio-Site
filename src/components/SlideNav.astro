---
// SlideNav component - Handles keyboard navigation between sections
---

<div id="slide-container" class="relative h-screen w-full overflow-x-hidden">
  <slot />
</div>

<!-- Section Indicator -->
<div class="fixed bottom-8 right-8 z-50 font-body text-sm">
  <span id="current-section" class="text-[var(--color-accent)] text-2xl font-bold">01</span>
  <span class="text-[var(--color-muted)]"> / 04</span>
</div>

<!-- Navigation Dots -->
<div class="fixed left-8 top-1/2 -translate-y-1/2 z-50 hidden sm:flex flex-col gap-4">
  {[0, 1, 2, 3].map((i) => (
    <button
      class="nav-dot w-2 h-2 rounded-full bg-[var(--color-muted)] hover:bg-[var(--color-accent)] transition-all duration-300"
      data-section={i}
      aria-label={`Go to section ${i + 1}`}
    />
  ))}
</div>

<!-- Keyboard Hint -->
<div class="fixed bottom-8 left-8 z-50 font-body text-xs text-[var(--color-muted)] hidden sm:flex gap-4">
  <span>← →</span>
  <span>1-4</span>
  <span>ESC</span>
</div>

<script>
  const sections = Array.from(document.querySelectorAll<HTMLElement>('.slide-section'));
  const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('.nav-dot'));
  const scrollRoot = document.getElementById('slide-scroll');
  let currentSection: number = 0;
  const totalSections: number = sections.length || 4;

  function setActiveSection(index: number) {
    if (index < 0 || index >= totalSections) return;

    currentSection = index;

    const indicator = document.getElementById('current-section');
    if (indicator) {
      indicator.textContent = String(index + 1).padStart(2, '0');
    }

    dots.forEach((dot, i) => {
      if (i === index) {
        dot.classList.add('bg-[var(--color-accent)]', 'h-8');
        dot.classList.remove('bg-[var(--color-muted)]', 'h-2');
      } else {
        dot.classList.remove('bg-[var(--color-accent)]', 'h-8');
        dot.classList.add('bg-[var(--color-muted)]', 'h-2');
      }
    });
  }

  function updateSection(index: number) {
    if (index < 0 || index >= totalSections) return;
    setActiveSection(index);
    sections[index]?.scrollIntoView({ behavior: 'smooth' });
  }

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    switch(e.key) {
      case 'ArrowRight':
      case 'ArrowDown':
        e.preventDefault();
        updateSection(currentSection + 1);
        break;
      case 'ArrowLeft':
      case 'ArrowUp':
        e.preventDefault();
        updateSection(currentSection - 1);
        break;
      case '1':
      case '2':
      case '3':
      case '4':
        e.preventDefault();
        updateSection(Number.parseInt(e.key, 10) - 1);
        break;
      case 'Escape':
        e.preventDefault();
        updateSection(0);
        break;
    }
  });

  // Dot navigation
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => updateSection(index));
  });

  if (scrollRoot && sections.length > 0) {
    const observer = new IntersectionObserver((entries) => {
      const visibleEntry = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

      if (!visibleEntry) return;

      const visibleIndex = sections.indexOf(visibleEntry.target as HTMLElement);
      setActiveSection(visibleIndex);
    }, {
      root: scrollRoot,
      threshold: [0.35, 0.6]
    });

    sections.forEach((section) => observer.observe(section));
  }

  setActiveSection(0);
</script>

<style>
  .nav-dot {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-dot.active {
    background-color: var(--color-accent);
    height: 2rem;
  }
</style>
