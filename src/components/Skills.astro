---
const skills = [
  { cat: "lang", items: ["Dart", "Python", "TypeScript", "JavaScript", "Java", "SQL"] },
  { cat: "mobile", items: ["Flutter", "Riverpod", "Drift", "SQLite", "Android basics"] },
  { cat: "api", items: ["FastAPI", "REST", "GraphQL", "SQLAlchemy", "JWT", "Celery"] },
  { cat: "quality", items: ["Docker", "GitHub Actions", "pytest", "Playwright", "JUnit", "OpenTelemetry"] }
];
---

<section class="slide-section h-screen w-full flex items-center justify-center relative px-6 md:px-16">
  <div class="max-w-7xl w-full">
    <div class="mb-12 md:mb-16">
      <div class="font-body text-sm text-[var(--color-muted)] mb-4">
        <span class="text-[var(--color-accent)]">$</span> cat ./stack.txt
      </div>
      <h2 class="font-heading text-4xl md:text-7xl mb-4">TECHNOLOGY<br/>STACK</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-12">
      {skills.map((category) => (
        <div class="border-l-2 border-[var(--color-accent)] pl-6">
          <div class="font-body text-xs text-[var(--color-accent)] mb-4 uppercase">
            ./{category.cat}
          </div>

          <div class="space-y-2">
            {category.items.map((skill) => (
              <div class="font-body text-sm font-light hover:text-[var(--color-accent)] transition-colors flex items-center gap-2">
                <span class="text-[var(--color-muted)]">-</span>
                <span>{skill}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 font-body text-xs text-[var(--color-muted)] border-t border-[var(--color-muted)] border-opacity-20 pt-4">
      <span class="text-[var(--color-accent)]">info:</span> stack compiled successfully
    </div>
  </div>
</section>
